# ===========================================
# 童裝訂單系統 - 環境變數範本
# ===========================================
# 複製此檔為 .env 並填入實際值
# 切勿將 .env 提交到版本控制！
# ===========================================

# ---------- 應用基本設定 ----------
NODE_ENV=development
APP_NAME=kidswear-b2b
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# ---------- 資料庫 ----------
# Docker Compose 內部連線用 "postgres" 當 hostname
DATABASE_URL=postgresql://user:pass@postgres:5432/kidswear
# 本機開發時用
# DATABASE_URL=postgresql://user:pass@localhost:5432/kidswear

# ---------- Redis ----------
REDIS_URL=redis://redis:6379
# 本機開發
# REDIS_URL=redis://localhost:6379

# ---------- JWT ----------
# 用 openssl rand -base64 64 產生
JWT_ACCESS_SECRET=<your-secret-here>
JWT_REFRESH_SECRET=<your-refresh-secret-here>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ---------- OAuth: LINE ----------
# 申請: https://developers.line.biz
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CALLBACK_URL=http://localhost:4000/api/v1/auth/line/callback

# ---------- OAuth: Google ----------
# 申請: https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# ---------- LINE Notify（批發商訂單推播）----------
# 申請: https://notify-bot.line.me/my/services/new
LINE_NOTIFY_CLIENT_ID=
LINE_NOTIFY_CLIENT_SECRET=
LINE_NOTIFY_REDIRECT_URI=http://localhost:4000/api/v1/auth/line-notify/callback

# ---------- Email（SMTP）----------
# Gmail: 需開啟 2FA 並產生 App Password（https://myaccount.google.com/apppasswords）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@kidswear.com

# ---------- 前端 URL ----------
FRONTEND_URL=http://localhost:3000

# ---------- 推薦服務 ----------
RECOMMENDER_URL=http://recommender:8000
# 本機
# RECOMMENDER_URL=http://localhost:8000

# ---------- Anthropic Claude API ----------
# 取得: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ---------- 檔案儲存（Cloudflare R2）----------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=kidswear-products
R2_PUBLIC_URL=https://<your-r2-subdomain>.r2.cloudflarestorage.com

# ---------- 加密金鑰 ----------
# 用於 OAuth token 加密
# openssl rand -hex 32
ENCRYPTION_KEY=

# ---------- 監控 ----------
SENTRY_DSN=
LOG_LEVEL=debug  # development: debug, production: info
